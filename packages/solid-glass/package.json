{
  "name": "solid-glass",
  "version": "1.0.0",
  "description": "A comprehensive glass effect toolkit for React \u2014 frosted, crystal, aurora, smoke, prism, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./effects": {
      "import": {
        "types": "./dist/effects/index.d.ts",
        "default": "./dist/effects/index.js"
      }
    },
    "./presets": {
      "import": {
        "types": "./dist/presets.d.ts",
        "default": "./dist/presets.js"
      }
    },
    "./css": "./dist/solid-glass.css",
    "./styles": "./dist/solid-glass.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "glass",
    "glassmorphism",
    "frosted-glass",
    "liquid-glass",
    "apple-ui",
    "react",
    "css",
    "ui-effects",
    "backdrop-filter",
    "blur"
  ],
  "author": "felix_m",
  "license": "Apache-2.0",
  "homepage": "https://iplanwebsites.github.io/solid-glass/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iplanwebsites/solid-glass.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3"
  }
}